{
	"name": "node-semantic-release",
	"version": "1.189.1",
	"description": "A semantic-release plugin to automate releases from a repository root.",
	"private": true,
	"scripts": {
		"clean": "rm -rf node_modules package-lock.json && npm cache clean --force",
		"install:safe": "npm install --legacy-peer-deps --node-gyp=./node_modules/.bin/node-gyp",
		"clean-install:safe": "npm run clean && npm run install:safe",
		"build": "echo 'Nothing to build'"
	},
	"dependencies": {
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"conventional-changelog-conventionalcommits": "^9.3.1",
		"semantic-release": "^25.0.5",
		"semantic-release-export-data": "^1.2.0"
	},
	"overrides": {
		"node-gyp": {
			"undici": ">=6.27.0 <7.0.0"
		},
		"@semantic-release/github": {
			"undici": ">=7.28.0 <8.0.0"
		},
		"@actions/http-client": {
			"undici": ">=6.27.0 <7.0.0"
		}
	}
}
